# ===================================================================
# v信 后端 .env 配置模板（新服务器部署照此填写，复制为 .env）
#   cp .env.example .env  然后按下面说明改值
# 标【必填】的必须改；标【可选】的不需要可整行删或留空。
# ===================================================================

# ── 基础 ───────────────────────────────────────────────────────────
PORT=3002                      # 监听端口（nginx 反代到此），默认 3002
NODE_ENV=production

# 【必填】本站对外完整地址（用于群邀请二维码链接；并会自动加入 CORS 白名单）
APP_URL=https://你的新域名.com

# 跨域来源。设了 APP_URL 一般就够了；如有额外前端域名再在这里补（逗号分隔）
# CORS_ORIGINS=https://admin.你的域名.com
# 只想用自己的域名、屏蔽内置旧域名白名单时打开下面这行：
# CORS_ORIGINS_ONLY=true

# ── 鉴权密钥（务必用随机长串；可用本仓库脚本生成，见 docs/换服务器与打包手册.md）──
# 【必填】JWT 签名密钥（换这个值会让所有人重新登录）
JWT_SECRET=粘贴一段随机长串

# ── 后台管理员（独立于普通用户）──
ADMIN_USERNAME=admin
ADMIN_PASSWORD=设一个强密码
ADMIN_JWT_SECRET=粘贴另一段随机长串
# 后台访问 IP 白名单（逗号分隔，留空=不限制）
# ADMIN_IP_WHITELIST=1.2.3.4

# 注册邀请码（留空=任何人可注册）
# INVITE_CODE=888888

# ── 数据与文件路径 ─────────────────────────────────────────────────
# 数据库文件路径（留空=用 backend-v2/wechat.db，全新部署会自动建空库）
# DB_PATH=/data/wechat.db
# 上传文件根目录（留空=用 backend-v2/uploads；迁移老数据时指到老的 uploads）
# UPLOADS_ROOT=/data/uploads

# ── Redis（【可选】不填自动降级内存模式，单机 1000 人在线够用）──
# REDIS_URL=redis://localhost:6379

# ── 文件存储（【可选】二选一）─────────────────────────────────────
#   不配 = 用「本地分片上传」，文件存在 UPLOADS_ROOT，由本服务 /uploads 提供，零外部依赖。
#   配 R2/OSS/COS = 客户端直传云存储，不占服务器带宽。下面以 Cloudflare R2 为例：
# CLOUD_PROVIDER=r2
# R2_ACCOUNT_ID=你的R2账户ID
# R2_BUCKET=你的桶名
# R2_ACCESS_KEY_ID=你的AccessKeyID
# R2_SECRET_ACCESS_KEY=你的SecretKey
# R2_PUBLIC_DOMAIN=files.你的域名.com   # 桶的公开访问域名（不填用 r2.dev 默认域）

# ── Web 推送 VAPID（【可选】网页端离线通知；用脚本生成一对密钥）──
# VAPID_PUBLIC_KEY=...
# VAPID_PRIVATE_KEY=...
# VAPID_EMAIL=mailto:admin@你的域名.com

# ── Firebase 云消息 FCM（【可选】安卓离线推送）──
# FIREBASE_PROJECT_ID=...
# FIREBASE_CLIENT_EMAIL=...
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── 音视频通话 TURN（【可选】但强烈建议；否则 4G/对称NAT 下通话接不通）──
#   自建 coturn，详见 backend-v2/docs/COTURN_SETUP.md
# TURN_SECRET=与 coturn static-auth-secret 一致
# TURN_URLS=turn:turn.你的域名.com:3478,turns:turn.你的域名.com:5349
# TURN_TTL=3600
# STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302

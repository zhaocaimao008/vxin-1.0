{
  "name": "vxin-desktop",
  "version": "2.0.1",
  "description": "v信 桌面客户端",
  "main": "src/main.js",
  "scripts": {
    "dev": "electron .",
    "build:web": "cd ../web && npx vite build --mode desktop",
    "build": "npm run build:web && electron-builder",
    "build:win": "npm run build:web && electron-builder --win --x64",
    "build:mac": "npm run build:web && electron-builder --mac --x64",
    "build:linux": "npm run build:web && electron-builder --linux --x64",
    "pack": "npm run build:web && electron-builder --dir",
    "postinstall": "electron-builder install-app-deps"
  },
  "_comment": "构建配置以 desktop-electron/package.json 为唯一来源；此文件不再保留 build 段以避免漂移。请始终从 desktop-electron/ 根目录构建。",
  "dependencies": {
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.0",
    "electron-log": "^5.0.0"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0"
  }
}

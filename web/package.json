{
  "name": "v-xin-web",
  "version": "2.0.1",
  "description": "v信 — 企业级安全即时通讯客户端",
  "homepage": "",
  "author": {
    "name": "v信",
    "email": ""
  },
  "main": "electron/main.js",
  "desktopName": "com.vxin.desktop",
  "scripts": {
    "dev": "vite --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "dev:desktop": "cross-env ELECTRON_DEV=1 concurrently -k --names \"VITE,ELECTRON\" -c \"cyan,green\" \"vite --port 3000\" \"wait-on http://localhost:3000 && electron .\"",
    "dev:desktop:headless": "cross-env ELECTRON_DEV=1 concurrently -k --names \"VITE,ELECTRON\" -c \"cyan,green\" \"vite --port 3000\" \"wait-on http://localhost:3000 && xvfb-run --auto-servernum electron .\"",
    "build:desktop": "vite build --mode desktop && electron-builder --linux",
    "build:desktop:headless": "vite build --mode desktop && electron-builder --linux",
    "build:desktop:win": "vite build --mode desktop && electron-builder --win",
    "build:desktop:mac": "vite build --mode desktop && electron-builder --mac",
    "pack:desktop": "vite build --mode desktop && electron-builder --dir",
    "dev:mobile": "ionic serve",
    "build:mobile": "npm run build && cap sync",
    "build:android": "npm run build && cap add android && cap sync android && cap open android",
    "build:ios": "npm run build && cap add ios && cap sync ios && cap open ios",
    "android:build": "cd android && ./gradlew assembleRelease",
    "ios:build": "cd ios && xcodebuild -workspace vxin.xcworkspace -scheme vxin -configuration Release",
    "android:run": "cd android && ./gradlew assembleDebug && adb install -r app/build/outputs/apk/debug/app-debug.apk",
    "ios:run": "cd ios && xcodebuild -workspace vxin.xcworkspace -scheme vxin",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "check:capacitor": "node scripts/check-capacitor-versions.mjs"
  },
  "dependencies": {
    "@capacitor/app": "^4.0.0",
    "@capacitor/camera": "^4.0.0",
    "@capacitor/core": "^4.0.0",
    "@capacitor/filesystem": "^4.0.0",
    "@capacitor/geolocation": "^4.0.0",
    "@capacitor/network": "^4.0.0",
    "@capacitor/push-notifications": "^4.0.0",
    "axios": "^1.6.7",
    "dompurify": "^3.0.6",
    "esbuild": "^0.28.1",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.1",
    "react-virtualized-auto-sizer": "^1.0.24",
    "react-window": "^1.8.11",
    "socket.io-client": "^4.7.4",
    "timeago.js": "^4.0.2"
  },
  "devDependencies": {
    "@capacitor/android": "^4.8.2",
    "@capacitor/cli": "^4.8.2",
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.2",
    "eslint": "^10.6.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "vite": "^8.0.16",
    "vite-plugin-singlefile": "^2.3.3",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.vxin.desktop",
    "productName": "v信",
    "copyright": "Copyright © 2026 v信",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "!node_modules"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Network",
      "icon": "build/icons",
      "description": "v信 — 企业级安全即时通讯",
      "syncDesktopName": true
    },
    "deb": {
      "maintainer": "v信 <admin@91aigu.com>",
      "depends": [
        "libgtk-3-0",
        "libnotify4",
        "libnss3",
        "libxss1",
        "libxtst6",
        "xdg-utils",
        "libatspi2.0-0",
        "libdrm2",
        "libgbm1"
      ]
    },
    "win": {
      "target": "nsis",
      "icon": "build/icons/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.social-networking"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "v信",
      "installerIcon": "build/icons/icon.ico",
      "uninstallerIcon": "build/icons/icon.ico",
      "installerHeaderIcon": "build/icons/icon.ico"
    }
  }
}

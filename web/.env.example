# v信 全平台环境变量配置
# 根据 NODE_ENV 自动选择对应的 .env 文件

# ============================================================================
# 通用配置 (所有平台)
# ============================================================================

# 应用名称
VITE_APP_NAME=v信

# API 端点
VITE_API_URL=https://api.your-domain.com
VITE_WS_URL=wss://api.your-domain.com

# 环境标识
VITE_ENV=production

# ============================================================================
# Web 平台 (浏览器)
# ============================================================================

VITE_WEB_DOMAIN=https://your-domain.com
VITE_WEB_SECURE=true

# ============================================================================
# Electron 平台 (Windows/Mac/Linux 桌面)
# ============================================================================

# 本地开发时使用的服务器
ELECTRON_DEV=0
VXIN_LOAD_LOCAL=0
VXIN_SERVER_URL=https://your-domain.com

# Electron 签名 (生产构建)
ELECTRON_CERTIFICATE_PASSWORD=
ELECTRON_WINDOWS_CERTIFICATE_PASSWORD=

# ============================================================================
# Capacitor 移动端 (iOS/Android)
# ============================================================================

# Capacitor app ID (与 capacitor.config.json 同步)
CAPACITOR_APP_ID=com.vxin.app
CAPACITOR_APP_NAME=v信

# iOS 相关
IOS_TEAM_ID=
IOS_BUNDLE_ID=com.vxin.app
IOS_PROVISIONING_PROFILE=

# Android 相关
ANDROID_PACKAGE_NAME=com.vxin.app
ANDROID_KEY_ALIAS=vxin
ANDROID_KEY_PASSWORD=
ANDROID_STORE_PASSWORD=

# ============================================================================
# Firebase (推送通知，可选)
# ============================================================================

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ============================================================================
# 分析 (Sentry 错误追踪)
# ============================================================================

VITE_SENTRY_DSN=

# ============================================================================
# 功能开关
# ============================================================================

# 启用深色模式
VITE_DARK_MODE=true

# 启用离线支持
VITE_OFFLINE_SUPPORT=true

# 启用推送通知
VITE_PUSH_NOTIFICATIONS=true

# 启用文件上传
VITE_FILE_UPLOAD=true
VITE_MAX_FILE_SIZE=104857600  # 100MB

# ============================================================================
# 日志级别
# ============================================================================

VITE_LOG_LEVEL=warn
NODE_ENV=production

# ============================================================================
# 使用说明
# ============================================================================

# 1. 复制此文件为对应的 .env 文件:
#    cp .env.example .env.production
#    cp .env.example .env.staging
#    cp .env.example .env.development
#
# 2. 修改对应的值
#
# 3. Vite 会自动在构建时注入这些变量
#
# 4. 在 React 中访问:
#    import.meta.env.VITE_API_URL
#
# 5. 敏感信息 (密钥、密码) 不要提交到 Git！
#    在 .gitignore 中添加: .env.local .env.*.local

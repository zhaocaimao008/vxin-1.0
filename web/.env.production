# ── v信 生产环境变量 ──────────────────────────────────────────
# 所有 VITE_ 前缀变量在构建时静态注入到前端 JS bundle
# 严禁在此文件存放私钥、JWT_SECRET 等机密（此文件可能进入版本库）

# ── 应用信息 ────────────────────────────────────────────────────
VITE_APP_NAME=v信
VITE_APP_VERSION=1.0.0

# ── API & WebSocket 地址 ────────────────────────────────────────
# 当前部署：前端与后端同源（Nginx 反代），使用相对路径即可
# Socket.io 连接 '/' → 页面为 HTTPS 时自动升级为 wss://，无需硬编码
VITE_API_BASE=
VITE_WS_URL=

# ── 启用跨域部署时取消注释（例如 CDN 托管前端、后端独立域名）──
# VITE_API_BASE=https://chat.91aigu.com
# VITE_WS_URL=wss://chat.91aigu.com

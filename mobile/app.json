{
  "expo": {
    "name": "v信",
    "slug": "v-xin",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#07C160"
    },
    "ios": {
      "bundleIdentifier": "com.vxin.app",
      "supportsTablet": true,
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "用于拍摄和发送图片",
        "NSMicrophoneUsageDescription": "用于语音消息和通话",
        "NSPhotoLibraryUsageDescription": "用于发送相册中的图片"
      }
    },
    "android": {
      "package": "com.vxin.app",
      "versionCode": 16,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon-foreground.png",
        "backgroundColor": "#07C160"
      },
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.BLUETOOTH",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.VIBRATE",
        "android.permission.ACCESS_NETWORK_STATE"
      ],
      "usesCleartextTraffic": true
    },
    "plugins": [
      "expo-image-picker",
      "expo-document-picker",
      "@config-plugins/react-native-webrtc"
    ],
    "extra": {
      "eas": {
        "projectId": "2de825d1-5a52-4516-976c-245d95429fff"
      }
    },
    "owner": "zhaocaimao01"
  }
}
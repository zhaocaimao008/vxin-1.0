{
  "cli": { "version": ">= 5.9.1" },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "ios": { "simulator": false }
    },
    "preview": {
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "ios": { "resourceClass": "m-medium" }
    },
    "production": {
      "android": { "buildType": "apk" },
      "ios": { "resourceClass": "m-medium" }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "your_apple_id@email.com",
        "ascAppId": "your_app_store_connect_app_id",
        "appleTeamId": "your_apple_team_id"
      }
    }
  }
}
